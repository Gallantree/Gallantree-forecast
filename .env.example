# MongoDB Atlas (pin cluster to ap-southeast-2 / Sydney)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/gallantree-forecast?retryWrites=true&w=majority

# Anthropic — enables the "Seed" feature on the Capital Programs tab. Without
# this key, the seed UI is disabled. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=

