# MongoDB Atlas (pin cluster to ap-southeast-2 / Sydney)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/gallantree-forecast?retryWrites=true&w=majority

# Anthropic — enables the "Seed" feature on the Capital Programs tab. Without
# this key, the seed UI is disabled. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=

# Auth.js v5 — magic-link auth for /admin routes
# AUTH_SECRET: generate with `openssl rand -base64 32`
AUTH_SECRET=
# AUTH_URL: base URL of this deployment (https in prod)
AUTH_URL=http://localhost:3000

# Google OAuth (optional — enables the "Continue with Google" button on /login)
# Configure at console.cloud.google.com → APIs & Services → Credentials.
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# SendGrid — sends the magic-link emails. Required in production; without it
# the magic link prints to the server console instead of being emailed.
# Generate at app.sendgrid.com → Settings → API Keys (Mail Send permission only)
SENDGRID_API_KEY=
# Verified sender (must match a verified SendGrid identity)
SENDGRID_FROM_EMAIL=noreply@gallantree.com.au
# Optional: SendGrid Dynamic Template ID (starts with "d-"). When set, the
# magic-link email is sent via the template. Available template variables:
#   {{loginUrl}}, {{magic_link}}, {{url}}, {{sign_in_url}}  → all the sign-in URL
#   {{loginCode}}                                            → blank (no OTP yet)
#   {{email}}                                                → recipient address
#   {{expires_minutes}}                                      → integer (e.g. 60)
#   {{expires_in}}                                           → "60 minutes"
# Leave blank to use the built-in inline HTML.
SENDGRID_LOGIN_EMAIL_ID=

# Xero (phase 2)
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# XERO_REDIRECT_URI=
